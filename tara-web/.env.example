# Example env file for the frontend (SvelteKit)
# Copy this file to `.env.local` for local development, or set this in your hosting platform's env vars.
#
# LEAVE THIS UNSET for the standard single-port deployment (FastAPI serves the
# built frontend and the API on the same origin). The app automatically uses
# `${window.location.origin}/api`, which works for localhost AND LAN/office
# access without any configuration.
#
# Only set VITE_API_BASE_URL when the API runs on a DIFFERENT origin than the
# frontend (e.g. separate API host, or `npm run dev` against a remote API).
# Do NOT point it at 127.0.0.1 for a shared deployment — remote clients cannot
# reach the server's loopback address.
#
# Full API base URL (include the /api path), e.g.:
# VITE_API_BASE_URL="https://quicktara.yourcompany.com/api"
